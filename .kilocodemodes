         }
         ```
      
      5️⃣ SSE Implementation:
         ```tsx
         'use client'
         
         useEffect(() => {
           const es = new EventSource('/api/events')
           es.onmessage = (event) => {
             const data = JSON.parse(event.data)
             setEvents(prev => [...prev, data])
           }
           es.onerror = () => {
             // Reconexión automática
             setTimeout(() => reconnect(), 5000)
           }
           return () => es.close()
         }, [])
         ```
      
